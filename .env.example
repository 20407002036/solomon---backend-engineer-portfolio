# API URL (Base URL for the Python backend)
# In development, this usually points to http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Notion Integration
# Get your API key from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_notion_api_key_here

# Database IDs (32-character strings from your Notion database URLs)
# Example URL: https://notion.so/workspace/DATABASE_ID?v=...
NOTION_PROJECTS_DATABASE_ID=your_projects_database_id_here
NOTION_BLOGS_DATABASE_ID=your_blogs_database_id_here
